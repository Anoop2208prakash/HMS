generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// 🔐 Core User Model
model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String   @unique
  password  String   // Hashed password
  role      Role     @default(PATIENT)
  
  // 📸 Cloudinary Integration
  avatar    String?  @default("")
  
  // 📞 Shared Contact Info
  phone     String?
  address   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  doctorProfile  Doctor?
  patientProfile Patient?
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
  STAFF   
}

// 🩺 Doctor Specific Data
model Doctor {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  specialization String
  department     String @default("General Medicine")
  experience     Int    @default(0)
  bio            String?
  
  userId         String @unique @db.ObjectId
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  appointments   Appointment[]
}

// 👤 Patient Specific Data
model Patient {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  dob       DateTime 
  gender    String
  bloodType String?
  
  userId    String   @unique @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 🚀 New Relations for Dashboard Features
  appointments  Appointment[]
  medications   Medication[]
  reports       Report[]
  vitals        Vitals[]

  createdAt DateTime @default(now())
}

// 📅 Appointments Logic
model Appointment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  date      DateTime
  reason    String?  
  status    String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  
  patientId String   @db.ObjectId
  patient   Patient  @relation(fields: [patientId], references: [id])
  
  doctorId  String   @db.ObjectId
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
}

// 💊 Medication / Prescription Data
model Medication {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  dosage    String   // e.g., "500mg"
  frequency String   // e.g., "1x Daily"
  status    String   @default("ACTIVE") // ACTIVE, COMPLETED
  
  patientId String   @db.ObjectId
  patient   Patient  @relation(fields: [patientId], references: [id])

  createdAt DateTime @default(now())
}

// 📄 Medical Reports Data
model Report {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String   // e.g., "Blood Test"
  type      String   // e.g., "LAB", "XRAY", "MRI"
  fileUrl   String   // Cloudinary URL
  
  patientId String   @db.ObjectId
  patient   Patient  @relation(fields: [patientId], references: [id])

  createdAt DateTime @default(now())
}

// 📊 Health Vitals (For Dashboard "Health Insights")
model Vitals {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  bloodPressure String?  // e.g., "120/80"
  glucose       String?  // e.g., "98 mg/dL"
  weight        Float?   // e.g., 72.5
  heartRate     Int?     // e.g., 72
  
  patientId     String   @db.ObjectId
  patient       Patient  @relation(fields: [patientId], references: [id])

  createdAt     DateTime @default(now())
}