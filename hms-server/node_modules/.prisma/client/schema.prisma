generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// 🔐 Core User Model for Login
model User {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  email    String @unique
  password String // Hashed password
  role     Role   @default(PATIENT)

  // 📸 Added for Cloudinary Integration
  avatar String? // The URL returned from Cloudinary

  // 📞 Additional Contact Info
  phone   String?
  address String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations to specific profiles
  doctorProfile  Doctor?
  patientProfile Patient?
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
  STAFF // Added STAFF role for general lab/hospital employees
}

// 🩺 Doctor Specific Data
model Doctor {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  specialization String
  experience     Int     @default(0)
  bio            String?

  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointments Appointment[]
}

// 👤 Patient Specific Data
model Patient {
  id        String  @id @default(auto()) @map("_id") @db.ObjectId
  age       Int
  gender    String
  bloodType String?

  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointments Appointment[]
  createdAt    DateTime      @default(now())
}

// 📅 Appointments Logic
model Appointment {
  id     String   @id @default(auto()) @map("_id") @db.ObjectId
  date   DateTime
  reason String? // Added to know why the patient is visiting
  status String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED

  patientId String  @db.ObjectId
  patient   Patient @relation(fields: [patientId], references: [id])

  doctorId String @db.ObjectId
  doctor   Doctor @relation(fields: [doctorId], references: [id])
}
